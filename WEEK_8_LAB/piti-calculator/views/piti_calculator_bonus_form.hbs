<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<body class="bg-light d-flex flex-column min-vh-100">
    <header class="border-bottom bg-white">
    <div class="container py-2">
        <div class="mx-auto" style="max-width: 1100px;">
        <h1 class="h3 mb-1">PITI Calculator</h1>
        <p class="text-muted mb-0">Enter your details to estimate your monthly payment.</p>
        </div>
    </div>
    </header>

  <main class="container py-2">
    <div class="mx-auto" style="max-width: 1100px;">
    <div class="row g-4 align-items-start">

      <!-- LEFT: Form -->
      <div class="col-lg-6">
        <div class="card shadow-sm">
          <div class="card-body p-3">
            <h2 class="h5 mb-3">Your loan information</h2>

            {{#if error}}
              <div class="alert alert-danger">{{error}}</div>
            {{/if}}

            <form action="/piti-calculator" method="post">
              <div class="mb-3">
                <label for="principal" class="form-label">Principal</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" class="form-control" id="principal" name="principal" step="0.01" required value="{{principal}}">
                </div>
              </div>

              <div class="mb-3">
                <label for="interestRate" class="form-label">Interest Rate</label>
                <div class="input-group">
                  <input type="number" class="form-control" id="interestRate" name="interest_rate" step="0.005" required value="{{interest_rate}}">
                  <span class="input-group-text">%</span>
                </div>
                <div class="form-text">Annual rate (example: 6.5).</div>
              </div>

              <div class="mb-3">
                <label class="form-label">Loan Term</label>
                <div class="row g-2">
                  <div class="col-6">
                    <div class="input-group">
                      <input type="number" class="form-control" id="loanTermYears" name="loan_term_years" min="0" value="{{loan_term_years}}">
                      <span class="input-group-text">years</span>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="input-group">
                      <input type="number" class="form-control" id="loanTermMonths" name="loan_term_months" min="0" placeholder="e.g., 120" value="{{loan_term_months}}">
                      <span class="input-group-text">months</span>
                    </div>
                  </div>
                </div>
                <div class="form-text">You can enter months only (example: 120) and leave years at 0.</div>
              </div>

              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label for="propertyTax" class="form-label">Property Tax (annual)</label>
                  <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input type="number" class="form-control" id="propertyTax" name="property_tax" step="0.01" value="{{property_tax}}">
                  </div>
                </div>
                <div class="col-6">
                  <label for="homeInsurance" class="form-label">Home Insurance (annual)</label>
                  <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input type="number" class="form-control" id="homeInsurance" name="home_insurance" step="0.01" value="{{home_insurance}}">
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label for="otherMonthly" class="form-label">Other Monthly Payments (optional)</label>
                <div class="input-group">
                  <span class="input-group-text">$</span>
                  <input type="number" class="form-control" id="otherMonthly" name="other_monthly" step="0.01" value="{{other_monthly}}">
                  <span class="input-group-text">/mo</span>
                </div>
                <div class="form-text">Example: HOA ($250/mo) or PMI ($90/mo).</div>
              </div>

              <button class="btn btn-primary w-100" type="submit">Calculate PITI</button>
            </form>
          </div>
        </div>
      </div>

      <!-- RIGHT: Results -->
      <div class="col-lg-6">
        <div class="card shadow-sm">
          <div class="card-body p-3">

            {{#if results}}
              <div class="d-flex justify-content-between align-items-baseline mb-2">
                <h2 class="h5 mb-0">Results</h2>
                <span class="badge text-bg-secondary">Estimate</span>
              </div>

              <div class="p-3 bg-light rounded mb-3">
                <div class="d-flex justify-content-between align-items-baseline">
                  <span class="fw-semibold">Estimated monthly payment (PITI)</span>
                  <span class="fs-4 fw-bold">${{monthly_payment}}</span>
                </div>
                <small class="text-muted">P&amp;I + taxes + insurance + optional monthly items.</small>
              </div>

              <div class="table-responsive mb-3">
                <table class="table table-sm align-middle">
                  <tbody>
                    <tr><th scope="row">Principal</th><td>${{principal}}</td></tr>
                    <tr><th scope="row">Interest Rate</th><td>{{interest_rate}}%</td></tr>
                    <tr><th scope="row">Loan Term</th><td>{{loan_term_display}}</td></tr>
                  </tbody>
                </table>
              </div>

              <h3 class="h6 mb-2">Monthly breakdown</h3>
              <ul class="list-group mb-3">
                <li class="list-group-item d-flex justify-content-between">
                  <span>Principal &amp; Interest</span>
                  <span class="fw-semibold">${{principal_and_interest}}</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                  <span>Property Tax</span>
                  <span class="fw-semibold">${{monthly_property_tax}}</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                  <span>Home Insurance</span>
                  <span class="fw-semibold">${{monthly_home_insurance}}</span>
                </li>
                {{#if has_other_monthly}}
                <li class="list-group-item d-flex justify-content-between">
                  <span>Other Monthly Payments</span>
                  <span class="fw-semibold">${{other_monthly}}</span>
                </li>
                {{/if}}
              </ul>

              <button class="btn btn-secondary"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#amortTable"
                      aria-expanded="false"
                      aria-controls="amortTable">
                Show Amortization Table
              </button>

              <div class="collapse mt-3" id="amortTable">
                <div class="card card-body">
                  <small class="text-muted d-block mb-2">
                    Amortization is principal + interest only.
                  </small>

                  <div class="table-responsive" style="max-height: 420px; overflow: auto;">
                    <table class="table table-sm table-striped mb-0">
                      <thead>
                        <tr>
                          <th>Month</th>
                          <th class="text-end">Payment</th>
                          <th class="text-end">Interest</th>
                          <th class="text-end">Principal</th>
                          <th class="text-end">Balance</th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each amortization}}
                        <tr>
                          <td>{{month}}</td>
                          <td class="text-end">${{payment}}</td>
                          <td class="text-end">${{interest}}</td>
                          <td class="text-end">${{principal}}</td>
                          <td class="text-end">${{balance}}</td>
                        </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>

            {{else}}
              <h2 class="h5 mb-2">Results</h2>
              <p class="text-muted mb-0">
                Enter your loan information and click <strong>Calculate PITI</strong>.
                Your results will appear here.
              </p>
            {{/if}}

          </div>
          <div class="card shadow-sm mt-4">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-baseline">
        <h3 class="h6 mb-0">Fill Missing (Principal / Rate / Payment)</h3>
        <span class="badge text-bg-secondary">PI only</span>
        </div>
        <p class="text-muted small mb-3">
        Enter any <strong>two</strong> fields below and click <strong>Fill Missing</strong>.
        Uses the loan term from the form on the left.
        </p>

        <div id="fillMissingMsg" class="alert alert-warning py-2 d-none" role="alert"></div>

        <div class="row g-2">
        <div class="col-md-4">
            <label class="form-label" for="fmPrincipal">Loan Amount</label>
            <div class="input-group">
            <span class="input-group-text">$</span>
            <input type="number" class="form-control" id="fmPrincipal" step="0.01" placeholder="e.g., 300000">
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="fmRate">Interest Rate</label>
            <div class="input-group">
            <input type="number" class="form-control" id="fmRate" step="0.001" placeholder="e.g., 6.5">
            <span class="input-group-text">%</span>
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="fmPayment">Monthly Payment</label>
            <div class="input-group">
            <span class="input-group-text">$</span>
            <input type="number" class="form-control" id="fmPayment" step="0.01" placeholder="e.g., 1896.20">
            </div>
        </div>
        </div>

        <button class="btn btn-secondary mt-3" type="button" id="fillMissingBtn">
        Fill Missing
        </button>
    </div>
</div>
        </div>
      </div>

    </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function showFillMsg(text, type = "warning") {
      const el = document.getElementById("fillMissingMsg");
      el.className = `alert alert-${type} py-2`;
      el.textContent = text;
      el.classList.remove("d-none");
    }

    function hideFillMsg() {
      document.getElementById("fillMissingMsg").classList.add("d-none");
    }

    function getLoanTermMonths() {
      // Reads your existing left-form inputs
      const years = Number(document.getElementById("loanTermYears")?.value || 0);
      const months = Number(document.getElementById("loanTermMonths")?.value || 0);
      const n = (years * 12) + months;
      return n;
    }

    function normalizeAnnualRate(input) {
      // Treat 6.5 as percent, 0.065 as decimal
      let r = Number(input);
      if (!Number.isFinite(r)) return NaN;
      if (r > 1) r = r / 100;
      return r; // annual decimal rate
    }

    function paymentFromPrincipalRate(P, annualRateDec, nMonths) {
      const r = annualRateDec / 12;
      if (r === 0) return P / nMonths;
      return (P * r) / (1 - Math.pow(1 + r, -nMonths));
    }

    function principalFromPaymentRate(M, annualRateDec, nMonths) {
      const r = annualRateDec / 12;
      if (r === 0) return M * nMonths;
      return (M * (1 - Math.pow(1 + r, -nMonths))) / r;
    }

    // Solve for annual rate (decimal) using bisection
    function rateFromPrincipalPayment(P, M, nMonths) {
      const paymentAtZero = P / nMonths;
      if (M < paymentAtZero) return null; // impossible

      let low = 0;       // annual decimal
      let high = 0.5;    // 50% annual to start
      // Increase high until payment(high) >= M or high gets too large
      while (paymentFromPrincipalRate(P, high, nMonths) < M && high < 5) {
        high *= 2; // up to 500% annual cap
      }
      if (high >= 5 && paymentFromPrincipalRate(P, high, nMonths) < M) return null;

      for (let i = 0; i < 80; i++) {
        const mid = (low + high) / 2;
        const pm = paymentFromPrincipalRate(P, mid, nMonths);
        if (pm > M) high = mid;
        else low = mid;
      }
      return (low + high) / 2;
    }

    document.getElementById("fillMissingBtn")?.addEventListener("click", () => {
      hideFillMsg();

      const n = getLoanTermMonths();
      if (!Number.isFinite(n) || n <= 0) {
        showFillMsg("Enter a valid loan term (years/months) in the form on the left first.", "warning");
        return;
      }

      const pEl = document.getElementById("fmPrincipal");
      const rEl = document.getElementById("fmRate");
      const mEl = document.getElementById("fmPayment");

      const pRaw = pEl.value.trim();
      const rRaw = rEl.value.trim();
      const mRaw = mEl.value.trim();

      const missing = [pRaw === "", rRaw === "", mRaw === ""].filter(Boolean).length;
      if (missing !== 1) {
        showFillMsg("Leave exactly ONE field blank (enter the other two).", "warning");
        return;
      }

      // Parse present values
      const P = pRaw === "" ? NaN : Number(pRaw);
      const M = mRaw === "" ? NaN : Number(mRaw);
      const annualRateDec = rRaw === "" ? NaN : normalizeAnnualRate(rRaw);

      // Basic validation
      if (pRaw !== "" && (!Number.isFinite(P) || P <= 0)) {
        showFillMsg("Loan amount must be a positive number.", "warning");
        return;
      }
      if (mRaw !== "" && (!Number.isFinite(M) || M <= 0)) {
        showFillMsg("Monthly payment must be a positive number.", "warning");
        return;
      }
      if (rRaw !== "" && (!Number.isFinite(annualRateDec) || annualRateDec < 0)) {
        showFillMsg("Interest rate must be 0 or a positive number.", "warning");
        return;
      }

      try {
        if (pRaw === "") {
          // Fill Principal
          const Pcalc = principalFromPaymentRate(M, annualRateDec, n);
          pEl.value = Pcalc.toFixed(2);
          showFillMsg("Filled loan amount.", "success");
        } else if (mRaw === "") {
          // Fill Monthly Payment
          const Mc = paymentFromPrincipalRate(P, annualRateDec, n);
          mEl.value = Mc.toFixed(2);
          showFillMsg("Filled monthly payment.", "success");
        } else {
          // Fill Rate
          const rateDec = rateFromPrincipalPayment(P, M, n);
          if (rateDec === null) {
            showFillMsg("Could not solve for rate with those values (check term/payment).", "warning");
            return;
          }
          rEl.value = (rateDec * 100).toFixed(3); // percent
          showFillMsg("Filled interest rate.", "success");
        }
      } catch (e) {
        showFillMsg("Something went wrong calculating the missing value.", "warning");
      }
    });
  </script>
</body>