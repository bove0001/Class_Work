<!-- This file is the template for the home page, which contains the BMI calculation form. -->
<div class="container py-5"> <!-- This div is a container that centers the content and adds padding. -->
  <div class="mx-auto" style="max-width: 480px;">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h1 class="h4 mb-3">BMI Calculator</h1>
        <p class="text-muted mb-4">Enter your weight and height to calculate your BMI.</p>

        <form action="/calculate" method="get"> <!-- This form is used to submit the weight and height data to the server -->
            <div class="mb-3">
                <label for="weight" class="form-label">Weight (kg)</label>
                <input type="number" class="form-control" id="weight" name="weight" step="0.1" required>
            </div>

            <div class="mb-3">
                <label for="height" class="form-label">Height (m)</label>
                <input type="number" class="form-control" id="height" name="height" step="0.01" required>
            </div>

            <button type="submit" class="btn btn-primary w-100">Calculate BMI</button> <!-- This button submits the form to the server to calculate the BMI. -->
        </form>
      </div>
    </div>
  </div>
</div>